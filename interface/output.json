{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "预制作导演板输出结果",
  "propertyOrdering": ["master_prompt_markdown", "generated_image_url"],
  "properties": {
    "master_prompt_markdown": {
      "type": "string",
      "title": "Markdown 提示词",
      "ui_component": "markdown_viewer"
    },
    "generated_image_url": {
      "type": ["string", "null"],
      "title": "最终结果图",
      "format": "uri",
      "ui_component": "image_viewer"
    }
  }
}
