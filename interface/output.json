{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "故事板输出结果",
  "propertyOrdering": [
    "master_prompt",
    "generated_image_url"
  ],
  "properties": {
    "master_prompt": {
      "type": "string",
      "title": "Master 提示词",
      "description": "用于生图的完整提示词全文，可直接复制使用。",
      "ui_component": "markdown_viewer"
    },
    "generated_image_url": {
      "type": ["string", "null"],
      "title": "最终分镜图",
      "format": "uri",
      "ui_component": "image_viewer"
    }
  }
}
