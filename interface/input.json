{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "故事板输入表单",
  "required": [
    "project_info",
    "provided_assets",
    "story_request"
  ],
  "properties": {
    "project_info": {
      "type": "object",
      "title": "项目信息",
      "ui_component": "section",
      "required": [
        "input_mode",
        "output_purpose"
      ],
      "properties": {
        "input_mode": {
          "type": "string",
          "title": "输入模式",
          "enum": [
            "素材与文本混合",
            "纯文本创作"
          ],
          "default": "素材与文本混合",
          "ui_component": "select"
        },
        "output_purpose": {
          "type": "string",
          "title": "输出形态",
          "enum": [
            "带文字导演故事板",
            "无文字分镜宫格图"
          ],
          "default": "带文字导演故事板",
          "ui_component": "select"
        }
      }
    },
    "provided_assets": {
      "type": "array",
      "title": "素材列表",
      "ui_component": "asset_uploader",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "role_tag",
          "asset_url"
        ],
        "properties": {
          "asset_id": {
            "type": "string",
            "title": "素材 ID",
            "ui_component": "text"
          },
          "role_tag": {
            "type": "string",
            "title": "素材角色",
            "enum": [
              "角色",
              "场景",
              "道具",
              "产品",
              "服装",
              "风格",
              "光照",
              "运动",
              "上一帧",
              "布局"
            ],
            "ui_component": "select"
          },
          "asset_url": {
            "type": "string",
            "title": "素材链接",
            "format": "uri",
            "ui_component": "image_uploader"
          },
          "description": {
            "type": "string",
            "title": "素材描述",
            "ui_component": "textarea"
          },
          "must_keep": {
            "type": "string",
            "title": "必须继承",
            "ui_component": "textarea"
          },
          "must_avoid": {
            "type": "string",
            "title": "禁止继承",
            "ui_component": "textarea"
          }
        }
      }
    },
    "story_request": {
      "type": "object",
      "title": "故事请求",
      "ui_component": "section",
      "required": [
        "story_framework"
      ],
      "properties": {
        "story_framework": {
          "type": "string",
          "title": "核心故事",
          "ui_component": "textarea"
        },
        "scene_description": {
          "type": "string",
          "title": "场景描述",
          "ui_component": "textarea"
        },
        "visual_goal": {
          "type": "string",
          "title": "视觉目标",
          "ui_component": "textarea"
        }
      }
    },
    "optional_parameters": {
      "type": "object",
      "title": "可选参数",
      "ui_component": "section",
      "properties": {
        "board_type_hint": {
          "type": "string",
          "title": "分镜类型偏好",
          "enum": [
            "动作推进",
            "空间建立",
            "转场",
            "情绪表演",
            "连续镜头",
            "多机位",
            "产品交互"
          ],
          "ui_component": "select"
        },
        "aspect_ratio": {
          "type": "string",
          "title": "画幅比例",
          "enum": [
            "16:9 横屏",
            "9:16 竖屏",
            "1:1 方形",
            "4:3 传统",
            "2.35:1 电影宽银幕"
          ],
          "default": "16:9 横屏",
          "ui_component": "select"
        },
        "image_quality": {
          "type": "string",
          "title": "输出画质",
          "enum": [
            "1K 标准",
            "2K 高清",
            "4K 超清"
          ],
          "default": "2K 高清",
          "ui_component": "select"
        },
        "panel_count_hint": {
          "type": "integer",
          "title": "镜头格数偏好",
          "minimum": 1,
          "maximum": 12,
          "ui_component": "number"
        },
        "duration_hint_seconds": {
          "type": "number",
          "title": "时长参考（秒）",
          "minimum": 0,
          "ui_component": "number"
        },
        "camera_movement_preference": {
          "type": "string",
          "title": "机位偏好",
          "enum": [
            "自动推断",
            "固定机位",
            "推镜头",
            "拉镜头",
            "摇摄",
            "跟拍",
            "环绕拍摄",
            "手持纪实"
          ],
          "default": "自动推断",
          "ui_component": "select"
        },
        "style_goal": {
          "type": "string",
          "title": "风格目标",
          "ui_component": "textarea"
        },
        "allow_minor_inference": {
          "type": "boolean",
          "title": "允许自动补全次要细节",
          "default": true,
          "ui_component": "checkbox"
        }
      }
    }
  }
}
